<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Klaviyo\Reclaim\Block\Catalog\Product\ViewedProduct;

/** @var ViewedProduct $block */
/** @var ViewModelRegistry $viewModels */

if (!$block->isKlaviyoEnabled()) {
    return;
}

/** @var HyvaCsp $hyvaCsp */
$hyvaCsp = $viewModels->require(HyvaCsp::class);

$viewedProductJson = $block->getViewedProductJson();
$viewedItemJson = $block->getViewedItemJson();
?>

<div x-data="klaviyoProductViewed"></div>

<script>
    function initKlaviyoProductViewed() {
        return {
            init() {
                if (!window.klaviyoConsentGranted || !window.klaviyoConsentGranted()) {
                    window.addEventListener('cookie-consent-updated', () => {
                        if (window.klaviyoConsentGranted && window.klaviyoConsentGranted()) {
                            this.track();
                        }
                    }, { once: true });
                    return;
                }
                this.track();
            },

            track() {
                // Klaviyo's onsite v3 SDK exposes track on window._learnq, not
                // window.klaviyo (the latter only carries identify/isIdentified
                // and a stub push that doesn't dispatch track events).
                window._learnq = window._learnq || [];
                window._learnq.push(['track', 'Viewed Product', <?= /* @noEscape */ $viewedProductJson ?>]);
                window._learnq.push(['trackViewedItem', <?= /* @noEscape */ $viewedItemJson ?>]);
            }
        };
    }

    // Register immediately if Alpine is already up; otherwise queue on
    // alpine:init. Prevents the race where Alpine processes the directive
    // before the factory is in the registry.
    if (window.Alpine && typeof window.Alpine.data === 'function') {
        window.Alpine.data('klaviyoProductViewed', initKlaviyoProductViewed);
    } else {
        document.addEventListener('alpine:init', () => {
            window.Alpine.data('klaviyoProductViewed', initKlaviyoProductViewed);
        }, { once: true });
    }
</script>
<?php $hyvaCsp->registerInlineScript() ?>
