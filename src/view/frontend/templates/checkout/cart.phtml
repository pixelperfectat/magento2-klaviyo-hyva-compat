<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Klaviyo\Reclaim\Block\Initialize;

/** @var Initialize $block */
/** @var ViewModelRegistry $viewModels */

if (!$block->isKlaviyoEnabled() || !$block->getPublicApiKey()) {
    return;
}

/** @var HyvaCsp $hyvaCsp */
$hyvaCsp = $viewModels->require(HyvaCsp::class);
?>

<div x-data="klaviyoCartTracking"></div>

<script>
    function initKlaviyoCartTracking() {
        return {
            init() {
                if (!window.klaviyoConsentGranted || !window.klaviyoConsentGranted()) {
                    window.addEventListener('cookie-consent-updated', () => {
                        if (window.klaviyoConsentGranted && window.klaviyoConsentGranted()) {
                            this.reload();
                        }
                    }, { once: true });
                    return;
                }
                this.reload();
            },

            reload() {
                fetch('/reclaim/checkout/reload', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        form_key: hyva.getFormKey()
                    })
                });
            }
        };
    }

    // Register the component immediately if Alpine is already loaded; otherwise
    // queue the registration on alpine:init. The previous pattern (always
    // registering inside the alpine:init listener) raced with Alpine's DOM
    // walker on pages where this template renders early in <body>: Alpine
    // processed <div x-data="klaviyoCartTracking"> before the factory was in
    // the registry, bound the factory after the fact, and never re-ran init().
    if (window.Alpine && typeof window.Alpine.data === 'function') {
        window.Alpine.data('klaviyoCartTracking', initKlaviyoCartTracking);
    } else {
        document.addEventListener('alpine:init', () => {
            window.Alpine.data('klaviyoCartTracking', initKlaviyoCartTracking);
        }, { once: true });
    }
</script>
<?php $hyvaCsp->registerInlineScript() ?>
