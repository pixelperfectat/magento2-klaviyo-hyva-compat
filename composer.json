{
    "name": "pixelperfectat/magento2-klaviyo-hyva-compat",
    "description": "Hyva Theme compatibility for Klaviyo_Reclaim. Based on hyva-themes/magento2-klaviyo-reclaim.",
    "type": "magento2-module",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "PixelPerfect",
            "homepage": "https://github.com/pixelperfectat"
        }
    ],
    "require": {
        "php": "^8.1",
        "hyva-themes/magento2-compat-module-fallback": "*",
        "klaviyo/magento2-extension": "*",
        "magento/framework": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "pixelperfectat/coding-standard": "^0.1.0"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "PixelPerfect\\KlaviyoHyvaCompat\\": "src/"
        }
    },
    "scripts": {
        "lint": "parallel-lint --exclude vendor .",
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "stan": "phpstan analyse",
        "test": "phpunit",
        "ci:validate": "@composer validate --no-check-publish",
        "check": [
            "@ci:validate",
            "@lint",
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "laminas/laminas-dependency-plugin": true,
            "magento/*": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.magento.com/"
        },
        {
            "type": "vcs",
            "url": "https://github.com/hyva-themes/magento2-compat-module-fallback.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/hyva-themes/magento2-theme-module.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/hyva-themes/magento2-mollie-theme-bundle.git"
        }
    ]
}
